# Z-Mobile-Manip 环境配置样板（复制为 .env 填值；.env 已 gitignore，密钥手工携带）
# VLM 消歧走 OpenRouter（CEO 2026-07-10 定案，弃 Qwen 直连 API）。

OPENROUTER_API_KEY=
ROS_DOMAIN_ID=20
GO2W_NUC_HOST=robot@go2w-nuc.local
GO2W_NUC_SSH_KEY=~/.ssh/id_ed25519_go2w_nuc
Z_MANIP_UI_URL=http://127.0.0.1:8766
# Generate these locally; never commit robot-specific calibration or Home data.
# Z_MANIP_CAMERA_CALIBRATION=/absolute/path/to/piper_wrist_camera_calibration.json
# Z_MANIP_ROBOT_URDF=/absolute/path/to/go2w_sensored.urdf
# PIPER_HOME_CONFIG=/absolute/path/to/private/piper_home.json
# 主力：Isaac 腕相机盲测通过，近期现场调用延迟和成功率更稳定。
Z_MANIP_VLM_MODEL=qwen/qwen3-vl-235b-a22b-instruct
# 同一几何质量门槛的后备；32B 在货架抓取盲测中未通过。
Z_MANIP_VLM_FALLBACK=qwen/qwen3.5-35b-a3b
Z_MANIP_VLM_PROVIDER_RETRIES=1
Z_MANIP_VLM_BASE_URL=https://openrouter.ai/api/v1

# 可选 learned 6DoF grasp providers；未配置时 cascade 自动落到本地 antipodal。
# Z_MANIP_HGGD_PROVIDER=hggd
# Z_MANIP_HGGD_ENDPOINT=tcp://127.0.0.1:5557
# Z_MANIP_HGGD_TIMEOUT_S=1.5
# Z_MANIP_DENSE_PROVIDER=anygrasp
# Z_MANIP_DENSE_ENDPOINT=tcp://127.0.0.1:5558

# 测试执行缝：sim=docker exec 进 navstack 容器；真机置空原生跑（见 tests/helpers.py）
# Z_MANIP_ROS_EXEC="docker exec navstack bash -lc"
